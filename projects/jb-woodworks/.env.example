# Author: RKOJ-ELENO :: 2026-05-23
# JB Woodworks - environment variables. Copy to .env.local for dev.

# Postgres connection (Railway provides DATABASE_URL automatically in prod).
# Local dev: install Postgres + create db jbwoodworks_dev.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jbwoodworks_dev?schema=public"

# Resend (transactional email) - get key at https://resend.com
RESEND_API_KEY=""
CONTACT_TO_EMAIL="jbwoodworks8@gmail.com"
CONTACT_FROM_EMAIL="JB Woodworks <noreply@jbwoodworks.example>"

# Fallback contact handler (used if RESEND_API_KEY is empty).
# Matches the v1 Vercel build's behavior. Inquiries POST here instead.
CONTACT_FORMSUBMIT_URL="https://formsubmit.co/jbwoodworks8@gmail.com"

# Public site URL (used for canonical links + OG)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
