# Author: RKOJ-ELENO :: 2026-05-23
# Copy to .env.local for dev, .env for prod. NEVER commit either file.

# Postgres connection string (self-hosted per HOSTING.md Path B).
DATABASE_URL="postgresql://showmasters:CHANGEME@localhost:5432/showmasters?schema=public"

# Cloudflare Turnstile (CAPTCHA on public forms)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Nano banana image-gen (placeholder — confirm with operator's other-agent setup)
NANO_BANANA_API_KEY=""
NANO_BANANA_MODEL="gemini-2.5-flash-image"

# Base URL for absolute links in API responses / sitemap
NEXT_PUBLIC_BASE_URL="https://showmasters.com"

# Outbound notification target — every new inquiry triggers an email here
INQUIRY_NOTIFY_EMAIL="Orders@ShowMasters.com"

# SMTP for the notification mailer (use your VPS sendmail OR an external SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Show Masters <noreply@showmasters.com>"
