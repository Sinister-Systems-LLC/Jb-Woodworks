# Author: RKOJ-ELENO :: 2026-05-25
# Ancestral Remotion .env.example
# Copy to .env to override defaults. NO SECRETS expected in this project.

# Target frame rate (default 30)
ANCESTRAL_FPS=30

# Max energy byte-rate used to normalize energy bar (default 2048 bytes/sec)
ANCESTRAL_ENERGY_MAX_BPS=2048

# Force-disable truecolor (set to 1 to use 256-color fallback)
ANCESTRAL_NO_TRUECOLOR=0

# Default project key used when SINISTER_ACTIVE_PROJECT_KEY is unset
ANCESTRAL_DEFAULT_PROJECT=sanctum

# Default render source (stdin | pipe:<path> | file:<path>)
ANCESTRAL_SOURCE=stdin
