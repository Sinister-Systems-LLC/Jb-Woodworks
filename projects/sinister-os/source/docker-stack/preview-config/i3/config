# i3 config for Sinister OS Phase 1A preview
# Author: RKOJ-ELENO :: 2026-05-25
#
# This is a SHIM — real Sinister OS ships Hyprland (Wayland) per master plan.
# i3 is the preview compositor because Wayland-in-a-container needs real GPU
# and a much heavier setup; i3 + Xvfb runs in any Docker host.

# Mod key (matches Sinister hotkey doctrine "Super+...")
set $mod Mod4

# Font
font pango:Cascadia Code 10

# Colors (Sinister purple accent)
set $bg          #100820
set $bg-alt      #181028
set $fg          #e8d6ff
set $accent      #c084fc
set $accent-dim  #6366f1
set $urgent      #ef4444

# Borders
default_border pixel 2
client.focused          $accent $accent $bg     $accent  $accent
client.focused_inactive $accent-dim $bg-alt $fg $bg-alt  $bg-alt
client.unfocused        $bg-alt $bg-alt $fg     $bg-alt  $bg-alt
client.urgent           $urgent $urgent $fg     $urgent  $urgent

# Gaps
gaps inner 8
gaps outer 4

# Background (xsetroot fallback since we have no compositor blur in preview)
exec --no-startup-id xsetroot -solid "#100820"

# Default workspace
workspace_auto_back_and_forth yes

# Hotkeys (matches master-plan § 5.1)
bindsym $mod+Return exec xterm -fa "Cascadia Code" -fs 11 -bg "$bg" -fg "$fg"
bindsym $mod+d      exec dmenu_run -nb "$bg-alt" -nf "$fg" -sb "$accent" -sf "$bg" -fn "Cascadia Code-10"
bindsym $mod+q      kill
bindsym $mod+e      exec --no-startup-id xterm -title "EVE chat" -e 'eve chat "$(zenity --entry --title=EVE --text=Message)"' || true

# Game-mode toggle (preview shim — calls daemon stub)
bindsym $mod+Shift+g exec --no-startup-id xterm -hold -e 'eve game-mode arm'

# Vim navigation
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Workspaces 1-9
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3

# Reload / restart
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exit

# Status bar
bar {
    position top
    status_command i3status
    colors {
        background $bg-alt
        statusline $fg
        focused_workspace  $accent $accent $bg
        active_workspace   $accent-dim $accent-dim $fg
        inactive_workspace $bg-alt $bg-alt $fg
        urgent_workspace   $urgent $urgent $fg
    }
    font pango:Cascadia Code 10
}
