# Containerfile.eve-daemon-stub — Python HTTP+UDS shim for EVE daemon
# Author: RKOJ-ELENO :: 2026-05-25
#
# Phase 1A stub. Implements a small subset of the state-machine doc 2026-05-25
# (states + intent socket) and the eve-llm bridge spec 2026-05-25 (chat.send
# proxy). Just enough for the preview UI to render something real.
#
# Build:    docker build -t sinister/eve-daemon-stub:dev -f Containerfile.eve-daemon-stub .

FROM python:3.12-alpine

RUN apk add --no-cache curl ca-certificates

WORKDIR /opt/eve-daemon-stub

# Tiny stdlib-only stub (no pip install needed)
COPY eve-daemon-stub.py /opt/eve-daemon-stub/eve-daemon-stub.py

EXPOSE 7331

HEALTHCHECK --interval=15s --timeout=3s --retries=5 \
    CMD wget -qO- http://localhost:7331/health || exit 1

CMD ["python", "/opt/eve-daemon-stub/eve-daemon-stub.py"]
