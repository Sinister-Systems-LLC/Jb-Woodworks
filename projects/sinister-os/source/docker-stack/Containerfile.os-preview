# Containerfile.os-preview — Sinister OS VM preview (Phase 1A)
# Author: RKOJ-ELENO :: 2026-05-25
#
# Arch base + Hyprland + waybar + the user-facing Sinister overlays, exposed
# via noVNC at port 6080. Operator opens browser, sees the OS, clicks around.
#
# Build:    docker build -t sinister/os-preview:dev -f Containerfile.os-preview .
# (Or use: python eve-vm.py up — which composes both this and the stubs.)

FROM archlinux:base-devel

# Layer 1: package install (cacheable). xorg + tigervnc + novnc + websockify
# give us a browser-reachable desktop without needing real GPU passthrough
# (Wayland-only in a container is fiddly; XWayland under TigerVNC is simpler
# for the preview tier).
RUN pacman -Syu --noconfirm && \
    pacman -S --noconfirm \
        # display + remote
        tigervnc novnc websockify xorg-server-xvfb \
        # compositor + WM (XWayland-friendly fallback uses i3 if hyprland needs Wayland)
        i3-wm xterm dmenu \
        # waybar + bar tooling (waybar handles X11 via XWayland but Hyprland needs Wayland)
        # We ship i3bar for the preview; full Hyprland lands when we ship the real ISO.
        # CLI surfaces
        bash curl wget jq git python python-requests sudo \
        # font + theme
        ttf-cascadia-code noto-fonts \
        # editor for operator's terminal
        vim \
        # systemd not available in container; use runit-style entrypoint script
        && pacman -Scc --noconfirm

# Layer 2: create the eve user (matches production OS user model)
RUN useradd -m -G wheel -s /bin/bash eve && \
    echo "eve ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/eve-preview && \
    chmod 0440 /etc/sudoers.d/eve-preview

# Layer 3: ship the `eve` CLI wrapper (talks to eve-daemon-stub over HTTP for now;
# real production uses /run/sinister/eve.sock UDS).
COPY preview-stubs/eve-cli /usr/local/bin/eve
RUN chmod +x /usr/local/bin/eve

# Layer 4: ship preview configs
COPY preview-config/i3 /home/eve/.config/i3
COPY preview-config/xterm/Xresources /home/eve/.Xresources
COPY preview-config/banner.txt /etc/sinister/banner.txt
RUN chown -R eve:eve /home/eve/.config /home/eve/.Xresources && \
    mkdir -p /var/log/sinister /var/lib/sinister/eve-llm /run/sinister && \
    chown -R eve:eve /var/log/sinister /var/lib/sinister /run/sinister

# Layer 5: preview entrypoint — starts Xvfb + i3 + x11vnc + noVNC
COPY preview-stubs/start-preview.sh /usr/local/bin/start-preview.sh
RUN chmod +x /usr/local/bin/start-preview.sh

EXPOSE 5900 6080 7331

# Healthcheck duplicated from compose for podman/docker-run usage
HEALTHCHECK --interval=30s --timeout=5s --retries=5 \
    CMD curl -sf http://localhost:6080/ > /dev/null || exit 1

ENTRYPOINT ["/usr/local/bin/start-preview.sh"]
