main() {
    if [ "$#" -eq 0 ]; then
        cmd_help
        exit 0
    fi

    local subcommand="$1"; shift

    case "${subcommand}" in
        up)             cmd_up "$@" ;;
        down)           cmd_down "$@" ;;
        restart)        cmd_restart "$@" ;;
        status)         cmd_status "$@" ;;
        smoke)          cmd_smoke "$@" ;;
        logs)           cmd_logs "$@" ;;
        clean)          cmd_clean "$@" ;;
        theme)          cmd_theme "$@" ;;
        mesh)           cmd_mesh "$@" ;;
        doh)            cmd_doh "$@" ;;
        proxy)          cmd_proxy "$@" ;;
        wg)             cmd_wg "$@" ;;
        panel)          cmd_panel "$@" ;;
        mode)           cmd_mode "$@" ;;
        doctor)         cmd_doctor "$@" ;;
        -h|--help|help) cmd_help ;;
        --version|-v)   cmd_version ;;
        *)
            err "unknown command: ${subcommand}"
            echo
            cmd_help
            exit 2
            ;;
    esac
}

main "$@"
