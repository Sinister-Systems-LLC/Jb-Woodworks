cmd_mode() {
    local action="${1:-}"; shift || true
    case "${action}" in
        get)
            goto_stack_dir
            if [ -f "${MODE_STATE_FILE}" ]; then
                cat "${MODE_STATE_FILE}"
            else
                printf 'mode = "unset"\n'
            fi
            ;;
        set)
            local target_mode="${1:-}"
            if [ "${target_mode}" != "desktop" ] && [ "${target_mode}" != "headless" ]; then
                err "usage: eve mode set {desktop|headless}"
                return 2
            fi
            goto_stack_dir
            mkdir -p "$(dirname "${MODE_STATE_FILE}")"
            local now
            now="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)"
            printf 'mode = "%s"\nset_at = "%s"\n' "${target_mode}" "${now}" > "${MODE_STATE_FILE}"
            ok "sinister-mode set: ${target_mode}"
            info "compose overlay: compose.${target_mode}.yml"
            info "P3+ install will additionally swap systemd default-target (graphical vs multi-user) and en/disable display manager."
            ;;
        verify)
            goto_stack_dir
            header "Variant overlays — syntax verification (no docker required)"
            local rc=0
            printf "  compose.desktop.yml ..... "
            if python -c "import yaml; yaml.safe_load(open('${DESKTOP_OVERLAY}'))" >/dev/null 2>&1; then
                printf "%sparse OK%s\n" "${C_GREEN}" "${C_RESET}"
            else
                printf "%sPARSE FAIL%s\n" "${C_RED}" "${C_RESET}"; rc=1
            fi
            printf "  compose.headless.yml .... "
            if python -c "import yaml; yaml.safe_load(open('${HEADLESS_OVERLAY}'))" >/dev/null 2>&1; then
                printf "%sparse OK%s\n" "${C_GREEN}" "${C_RESET}"
            else
                printf "%sPARSE FAIL%s\n" "${C_RED}" "${C_RESET}"; rc=1
            fi
            printf "  mode state file ......... "
            if [ -f "${MODE_STATE_FILE}" ]; then
                local mode
                mode="$(grep -E '^mode\s*=' "${MODE_STATE_FILE}" | head -1 | sed -E 's/.*= *"([^"]+)".*/\1/')"
                printf "%spresent (mode=%s)%s\n" "${C_GREEN}" "${mode}" "${C_RESET}"
            else
                printf "%sunset%s\n" "${C_YELLOW}" "${C_RESET}"
            fi
            if [ "${rc}" = "0" ]; then
                ok "variant scaffold verified."
            else
                err "variant scaffold has issues."
            fi
            return "${rc}"
            ;;
        ""|-h|--help|help)
            cat <<EOF
${C_PURPLE}${C_BOLD}eve mode${C_RESET} — Sinister OS variant toggle (desktop / headless)

${C_BOLD}USAGE${C_RESET}
  eve mode <subcommand> [args]

${C_BOLD}SUBCOMMANDS${C_RESET}
  get                       Print current mode state (./config/sinister/mode.toml).
  set {desktop|headless}    Write mode state. P3+ will additionally swap systemd target.
  verify                    Syntax-check both variant overlays + report current mode.
  help                      This help.

${C_BOLD}VARIANTS${C_RESET}
  desktop    Main-PC variant: Hyprland kiosk + Sinister Panel + native apps (Steam, IDEs).
  headless   Server variant: no GUI; Panel served on mesh (0.0.0.0:3082).

${C_BOLD}HONEST STATUS${C_RESET}
  In docker context, eve mode writes state to ./config/sinister/mode.toml
  and selects which compose overlay you bring up. On a real Sinister OS install,
  P3+ adds /usr/local/bin/eve-mode which additionally:
    - writes /etc/sinister/mode.toml
    - systemctl set-default {graphical|multi-user}.target
    - enable/disable sddm.service + hyprland.service

${C_DIM}See docs/variants-design-2026-05-24.md for full design + scope ledger.${C_RESET}
EOF
            ;;
        *)
            err "unknown subcommand: mode ${action}"
