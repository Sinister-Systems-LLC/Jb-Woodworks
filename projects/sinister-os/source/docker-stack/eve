#!/usr/bin/env bash
# eve — docker-stack manager CLI for the Sinister Mesh OS
# Author: RKOJ-ELENO :: 2026-05-24
#
# Purpose:
#   A thin shell wrapper around the most common docker-compose operations the
#   operator performs daily on the Sinister Mesh docker-stack. One verb per
#   intent (up / down / restart / logs / status / smoke / clean / theme /
#   doctor) so the operator never has to remember the long compose invocations.
#
# Motivating operator directive (verbatim, 2026-05-24):
#   "i can forever expand and update the OS without having to reinstall etc.
#    and have quality of life options ... soft reboot or clearing caches
#    without full restart or fucking with my agents all things like this"
#
# Scope:
#   This is the DOCKER-STACK MANAGER variant of `eve`. The system-level EVE
#   daemon (root-equivalent shell control, voice surface, sinister-eve.service)
#   is operator-gated for P3 and lives at source/eve-control/. THIS script
#   does NOT touch system services, sudoers, or compositor configs.
#
# Conventions:
#   - All compose calls auto-cd into this script's own directory.
#   - Color output is purple (Sanctum convention) when stdout is a tty.
#   - No emojis (operator preference).
#   - Exits non-zero on any sub-command failure (set -euo pipefail).

set -euo pipefail

readonly EVE_VERSION="0.1.0"
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly COMPOSE_FILE="docker-compose.yml"
readonly HARDENED_OVERLAY="compose.hardened.yml"
readonly MESH_OVERLAY="compose.mesh.yml"
readonly DOH_OVERLAY="compose.doh.yml"
readonly DOH_CONFIG="config/cloudflared/config.yml"
readonly DOH_CONTAINER="sinister-cloudflared"
readonly OVERRIDE_LINK="docker-compose.override.yml"
readonly SMOKE_SCRIPT="smoke-test.sh"
readonly PROXY_ROUTES_FILE="config/proxy/routes.json"
readonly PROXY_VALID_ROUTES="direct ny fl tor"
readonly WG_FALLBACK_OVERLAY="compose.wg-fallback.yml"
readonly PANEL_SHELL_OVERLAY="compose.panel-shell.yml"
readonly DESKTOP_OVERLAY="compose.desktop.yml"
readonly HEADLESS_OVERLAY="compose.headless.yml"
# Mode state file (created in docker context at ./config/sinister/mode.toml;
# on a real install, lives at /etc/sinister/mode.toml).
readonly MODE_STATE_FILE="config/sinister/mode.toml"

# ---------------------------------------------------------------------------
# Color helpers (degrade gracefully when piped)
# ---------------------------------------------------------------------------
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    readonly C_PURPLE=$'\033[35m'
    readonly C_BOLD=$'\033[1m'
    readonly C_DIM=$'\033[2m'
    readonly C_RED=$'\033[31m'
    readonly C_GREEN=$'\033[32m'
    readonly C_YELLOW=$'\033[33m'
    readonly C_RESET=$'\033[0m'
else
    readonly C_PURPLE=""
    readonly C_BOLD=""
    readonly C_DIM=""
    readonly C_RED=""
    readonly C_GREEN=""
    readonly C_YELLOW=""
    readonly C_RESET=""
fi

header() {
    printf "%s==> %s%s\n" "${C_PURPLE}${C_BOLD}" "$*" "${C_RESET}"
}

info() {
    printf "%s%s%s\n" "${C_DIM}" "$*" "${C_RESET}"
}

ok() {
    printf "%s[OK]%s %s\n" "${C_GREEN}" "${C_RESET}" "$*"
}

warn() {
    printf "%s[WARN]%s %s\n" "${C_YELLOW}" "${C_RESET}" "$*" >&2
}

err() {
    printf "%s[ERR]%s %s\n" "${C_RED}" "${C_RESET}" "$*" >&2
}

# ---------------------------------------------------------------------------
# Pre-flight: cd into script dir, confirm docker is reachable for cmds that need it
# ---------------------------------------------------------------------------
goto_stack_dir() {
    cd "${SCRIPT_DIR}"
}

require_docker() {
    if ! command -v docker >/dev/null 2>&1; then
        err "docker not on PATH"
        return 1
    fi
    if ! docker info >/dev/null 2>&1; then
        err "docker daemon not reachable (is Docker Desktop running?)"
        return 1
    fi
}

# Build the array of -f flags. Default: base + hardened overlay.
compose_flags() {
    local no_harden="${1:-0}"
    printf -- "-f %s" "${COMPOSE_FILE}"
    if [ "${no_harden}" != "1" ] && [ -f "${HARDENED_OVERLAY}" ]; then
        printf -- " -f %s" "${HARDENED_OVERLAY}"
    fi
}

# ---------------------------------------------------------------------------
# Sub-commands
# ---------------------------------------------------------------------------

cmd_up() {
    local no_harden=0
    for arg in "$@"; do
        case "${arg}" in
            --no-harden) no_harden=1 ;;
            *) warn "unknown flag to 'up': ${arg}" ;;
        esac
    done
    goto_stack_dir
    require_docker
    if [ "${no_harden}" = "1" ]; then
        header "Bringing up stack (base only — no hardening overlay)"
        docker compose -f "${COMPOSE_FILE}" up -d
    else
        header "Bringing up stack (hardened by default)"
        docker compose -f "${COMPOSE_FILE}" -f "${HARDENED_OVERLAY}" up -d
    fi
    ok "stack is up. Run 'eve status' to verify."
}

cmd_down() {
    local wipe=0
    for arg in "$@"; do
        case "${arg}" in
            --wipe) wipe=1 ;;
            *) warn "unknown flag to 'down': ${arg}" ;;
        esac
    done
    goto_stack_dir
    require_docker
    if [ "${wipe}" = "1" ]; then
        header "DESTRUCTIVE: down -v will remove all named volumes"
        printf "%s" "Type 'WIPE' to confirm volume deletion: "
        read -r confirm
        if [ "${confirm}" != "WIPE" ]; then
            err "aborted (confirmation did not match)"
            return 1
        fi
        docker compose down -v
        ok "stack down and volumes wiped."
    else
        header "Bringing stack down (volumes preserved)"
        docker compose down
        ok "stack down. Volumes intact."
    fi
}

cmd_restart() {
    goto_stack_dir
    require_docker
    if [ "$#" -eq 0 ]; then
        header "Restarting all services (volumes untouched)"
        docker compose restart
    else
        header "Restarting service(s): $*"
        docker compose restart "$@"
    fi
    ok "restart complete."
}

cmd_status() {
    goto_stack_dir
    require_docker
    header "Compose service status"
    docker compose ps
    echo
    if [ -x "${SMOKE_SCRIPT}" ]; then
        header "Smoke test"
        bash "${SMOKE_SCRIPT}" || warn "smoke test reported failures"
    else
        warn "${SMOKE_SCRIPT} not executable; skipping smoke phase"
    fi
}

cmd_smoke() {
    goto_stack_dir
    if [ ! -f "${SMOKE_SCRIPT}" ]; then
        err "${SMOKE_SCRIPT} not found in ${SCRIPT_DIR}"
        return 1
    fi
    bash "${SMOKE_SCRIPT}"
}

cmd_logs() {
    goto_stack_dir
    require_docker
    if [ "$#" -eq 0 ]; then
        header "Tailing all service logs (Ctrl-C to stop)"
        docker compose logs -f --tail=100
    else
        header "Tailing logs for: $*"
        docker compose logs -f --tail=100 "$@"
    fi
}

cmd_clean() {
    goto_stack_dir
    require_docker
    header "Soft cache clear — agents and volumes untouched"
    info "Running: docker system prune -f (volumes preserved)"
    docker system prune -f
    info "Restarting panel + rocketchat-mongo-init"
    # Best-effort restart of cache-sensitive services.
    docker compose restart panel 2>/dev/null || warn "panel restart skipped (service not running)"
    docker compose restart rocketchat-mongo-init 2>/dev/null || warn "rocketchat-mongo-init restart skipped (service not running)"
    ok "soft cache clear complete. Agents remain online."
}

cmd_theme() {
    local action="${1:-}"; shift || true
    case "${action}" in
        list)
            goto_stack_dir
            header "Available theme overlays"
            # For now, just compose.hardened.yml. Future overlays land alongside.
            local found=0
            for f in compose.*.yml; do
                if [ -f "${f}" ]; then
                    local name="${f#compose.}"
                    name="${name%.yml}"
                    local active=""
                    if [ -L "${OVERRIDE_LINK}" ] && [ "$(readlink "${OVERRIDE_LINK}")" = "${f}" ]; then
                        active=" ${C_GREEN}(active)${C_RESET}"
                    fi
                    printf "  - %s%s\n" "${name}" "${active}"
                    found=1
                fi
            done
            if [ "${found}" = "0" ]; then
                info "no overlays found (looked for compose.*.yml)"
            fi
            ;;
        apply)
            local name="${1:-}"
            if [ -z "${name}" ]; then
                err "usage: eve theme apply <name>"
                return 1
            fi
            goto_stack_dir
            local target="compose.${name}.yml"
            if [ ! -f "${target}" ]; then
                err "overlay not found: ${target}"
                return 1
            fi
            header "Applying theme overlay: ${name}"
            if [ -e "${OVERRIDE_LINK}" ] || [ -L "${OVERRIDE_LINK}" ]; then
                rm -f "${OVERRIDE_LINK}"
            fi
            ln -s "${target}" "${OVERRIDE_LINK}"
            ok "linked ${OVERRIDE_LINK} -> ${target}. Compose will auto-load it next 'up'."
            ;;
        ""|*)
            err "usage: eve theme {list|apply <name>}"
            return 1
            ;;
    esac
}

cmd_doctor() {
    goto_stack_dir
    header "EVE doctor — health-check report"
    local issues=0

    # 1. Docker daemon
    printf "  daemon ............ "
    if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
        printf "%sup%s\n" "${C_GREEN}" "${C_RESET}"
    else
        printf "%sDOWN%s\n" "${C_RED}" "${C_RESET}"
        issues=$((issues+1))
    fi

    # 2. Compose file present
    printf "  compose file ...... "
    if [ -f "${COMPOSE_FILE}" ]; then
        printf "%sfound%s\n" "${C_GREEN}" "${C_RESET}"
    else
        printf "%sMISSING%s\n" "${C_RED}" "${C_RESET}"
        issues=$((issues+1))
    fi

    # 3. Hardened overlay present
    printf "  hardened overlay .. "
    if [ -f "${HARDENED_OVERLAY}" ]; then
        printf "%sfound%s\n" "${C_GREEN}" "${C_RESET}"
    else
        printf "%smissing (will up without hardening)%s\n" "${C_YELLOW}" "${C_RESET}"
    fi

    # 4. Smoke test executable
    printf "  smoke-test.sh ..... "
    if [ -x "${SMOKE_SCRIPT}" ]; then
        printf "%sexecutable%s\n" "${C_GREEN}" "${C_RESET}"
    else
        printf "%snot executable%s\n" "${C_YELLOW}" "${C_RESET}"
    fi

    # 5. Images pulled (best-effort — requires daemon)
    if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
        printf "  images present .... "
        local missing
        missing=$(docker compose -f "${COMPOSE_FILE}" config --images 2>/dev/null \
            | sort -u \
            | while read -r img; do
                if ! docker image inspect "${img}" >/dev/null 2>&1; then
                    printf "%s\n" "${img}"
                fi
            done | wc -l | tr -d ' ')
        if [ "${missing}" = "0" ]; then
            printf "%sall present%s\n" "${C_GREEN}" "${C_RESET}"
        else
            printf "%s%s image(s) not yet pulled%s\n" "${C_YELLOW}" "${missing}" "${C_RESET}"
        fi

        # 6. Named volumes
        printf "  volumes ........... "
        local vol_missing
        vol_missing=$(docker compose -f "${COMPOSE_FILE}" config --volumes 2>/dev/null \
            | while read -r v; do
                if ! docker volume inspect "${v}" >/dev/null 2>&1; then
                    printf "%s\n" "${v}"
                fi
            done | wc -l | tr -d ' ')
        if [ "${vol_missing}" = "0" ]; then
            printf "%sall present%s\n" "${C_GREEN}" "${C_RESET}"
        else
            printf "%s%s volume(s) will be created on next 'up'%s\n" "${C_DIM}" "${vol_missing}" "${C_RESET}"
        fi
    else
        info "  (image / volume / port checks skipped: docker daemon unreachable)"
    fi

    # 7. Ports free (best-effort using ss/netstat)
    printf "  ports free check .. "
    local port_tool=""
    if command -v ss >/dev/null 2>&1; then port_tool="ss"
    elif command -v netstat >/dev/null 2>&1; then port_tool="netstat"
    fi
    if [ -n "${port_tool}" ]; then
        local stack_ports="3081 8030 28384 8222 1234 11434 5079 8060 8090 8050"
        local in_use=0
        for p in ${stack_ports}; do
            if [ "${port_tool}" = "ss" ]; then
                if ss -tln 2>/dev/null | grep -q ":${p} "; then in_use=$((in_use+1)); fi
            else
                if netstat -an 2>/dev/null | grep -q "[.:]${p} .*LISTEN"; then in_use=$((in_use+1)); fi
            fi
        done
        if [ "${in_use}" = "0" ]; then
            printf "%sall free%s\n" "${C_GREEN}" "${C_RESET}"
        else
            printf "%s%s of 10 already bound (likely the stack itself)%s\n" "${C_DIM}" "${in_use}" "${C_RESET}"
        fi
    else
        printf "%sno ss/netstat available%s\n" "${C_DIM}" "${C_RESET}"
    fi

    echo
    if [ "${issues}" = "0" ]; then
        ok "doctor: no blocking issues."
        return 0
    else
        err "doctor: ${issues} blocking issue(s) found."
        return 1
    fi
}

cmd_mesh() {
    local action="${1:-}"; shift || true
    case "${action}" in
        up)
            goto_stack_dir
            require_docker
            if [ ! -f "${MESH_OVERLAY}" ]; then
                err "${MESH_OVERLAY} not found in ${SCRIPT_DIR}"
                return 1
            fi
            if [ -z "${TS_AUTHKEY:-}" ]; then
                err "TS_AUTHKEY not set in env"
                info "Generate one at https://login.tailscale.com/admin/settings/keys"
                info "Then: export TS_AUTHKEY=tskey-auth-..."
                return 1
            fi
            : "${TS_HOSTNAME:=sinister-mesh-$(hostname -s 2>/dev/null || echo node)}"
            : "${TS_EXTRA_ARGS:=--accept-routes --accept-dns=false}"
            export TS_HOSTNAME TS_EXTRA_ARGS
            header "Bringing up mesh sidecar (host=${TS_HOSTNAME})"
            info "Extra args: ${TS_EXTRA_ARGS}"
            docker compose -f "${COMPOSE_FILE}" -f "${HARDENED_OVERLAY}" -f "${MESH_OVERLAY}" up -d tailscale
            ok "tailscale sidecar started. Run 'eve mesh status' for tailnet status."
            ;;
        down)
            goto_stack_dir
            require_docker
            header "Stopping mesh sidecar (tailnet node stays registered)"
            docker compose -f "${COMPOSE_FILE}" -f "${MESH_OVERLAY}" stop tailscale 2>/dev/null \
                || warn "tailscale service not running"
            docker compose -f "${COMPOSE_FILE}" -f "${MESH_OVERLAY}" rm -f tailscale 2>/dev/null \
                || true
            ok "mesh sidecar down. State volume preserved."
            ;;
        status)
            goto_stack_dir
            require_docker
            if ! docker ps --format '{{.Names}}' | grep -q '^sinister-tailscale$'; then
                err "sinister-tailscale not running"
                info "Bring up with: eve mesh up"
                return 1
            fi
            header "Tailscale status"
            docker exec sinister-tailscale tailscale status || warn "tailscale status returned non-zero"
            ;;
        peers)
            goto_stack_dir
            require_docker
            if ! docker ps --format '{{.Names}}' | grep -q '^sinister-tailscale$'; then
                err "sinister-tailscale not running"
                return 1
            fi
            header "Tailscale peers (JSON)"
            docker exec sinister-tailscale tailscale status --peers --json \
                | python -m json.tool 2>/dev/null \
                || docker exec sinister-tailscale tailscale status --peers
            ;;
        ping)
            local peer="${1:-}"
            if [ -z "${peer}" ]; then
                err "usage: eve mesh ping <peer-name>"
                return 1
            fi
            goto_stack_dir
            require_docker
            header "Ping ${peer} via tailnet"
            docker exec sinister-tailscale tailscale ping "${peer}"
            ;;
        verify)
            goto_stack_dir
            header "Mesh artifacts — syntax verification (no docker required)"
            local rc=0
            printf "  compose.mesh.yml ........ "
            if python -c "import yaml; yaml.safe_load(open('${MESH_OVERLAY}'))" >/dev/null 2>&1; then
                printf "%sparse OK%s\n" "${C_GREEN}" "${C_RESET}"
            else
                printf "%sPARSE FAIL%s\n" "${C_RED}" "${C_RESET}"; rc=1
            fi
            printf "  acl.json template ....... "
            if python -c "import json; json.load(open('config/tailscale/acl.json'))" >/dev/null 2>&1; then
                printf "%sparse OK%s\n" "${C_GREEN}" "${C_RESET}"
            else
                printf "%sPARSE FAIL%s\n" "${C_RED}" "${C_RESET}"; rc=1
            fi
            printf "  MESH-DEPLOY.md .......... "
            if [ -f "MESH-DEPLOY.md" ]; then
                printf "%spresent%s\n" "${C_GREEN}" "${C_RESET}"
            else
                printf "%sMISSING%s\n" "${C_RED}" "${C_RESET}"; rc=1
            fi
            if [ "${rc}" = "0" ]; then
                ok "mesh scaffold verified."
            else
                err "mesh scaffold has issues."
            fi
            return "${rc}"
            ;;
        ""|-h|--help|help)
            cat <<EOF
${C_PURPLE}${C_BOLD}eve mesh${C_RESET} — Tailscale mesh management (M5 scaffold)

${C_BOLD}USAGE${C_RESET}
  eve mesh <subcommand> [args]

${C_BOLD}SUBCOMMANDS${C_RESET}
  up                  Start the tailscale sidecar. Requires TS_AUTHKEY in env.
                      Optional: TS_HOSTNAME, TS_EXTRA_ARGS.
  down                Stop and remove the tailscale sidecar (state volume kept).
  status              Show 'tailscale status' inside the sidecar.
  peers               Print peers as JSON (falls back to plain text if no python).
  ping <peer-name>    Tailscale ping to a named peer.
  verify              Syntax-check mesh artifacts (no docker daemon required).

${C_BOLD}EXAMPLES${C_RESET}
  export TS_AUTHKEY=tskey-auth-...
  export TS_HOSTNAME=sinister-mesh-ny
  export TS_EXTRA_ARGS="--advertise-exit-node --advertise-tags=tag:server"
  eve mesh up
  eve mesh status
  eve mesh ping sinister-mesh-fl

${C_DIM}See MESH-DEPLOY.md for the full operator runbook (account setup, ACL apply, exit-node toggle).${C_RESET}
EOF
            ;;
        *)
            err "unknown subcommand: mesh ${action}"
            info "run 'eve mesh' for help"
            return 1
            ;;
    esac
}

cmd_doh() {
    local action="${1:-}"; shift || true
    case "${action}" in
        up)
            goto_stack_dir
            require_docker
            if [ ! -f "${DOH_OVERLAY}" ]; then
                err "${DOH_OVERLAY} not found in ${SCRIPT_DIR}"
                return 1
            fi
            header "Bringing up cloudflared DoH sidecar"
            docker compose -f "${COMPOSE_FILE}" -f "${DOH_OVERLAY}" up -d cloudflared
            ok "cloudflared started. Run 'eve doh status' to verify."
            ;;
        down)
            goto_stack_dir
            require_docker
            header "Stopping cloudflared DoH sidecar"
            if [ -f "${DOH_OVERLAY}" ]; then
                docker compose -f "${COMPOSE_FILE}" -f "${DOH_OVERLAY}" down cloudflared 2>/dev/null \
                    || docker stop "${DOH_CONTAINER}" 2>/dev/null \
                    || warn "cloudflared not running"
            else
                docker stop "${DOH_CONTAINER}" 2>/dev/null \
                    || warn "cloudflared not running"
            fi
            ok "cloudflared down."
            ;;
        status)
            goto_stack_dir
            require_docker
            header "Cloudflared DoH container status"
            docker ps --filter "name=${DOH_CONTAINER}"
            ;;
        verify)
            goto_stack_dir
            header "DoH artifacts — syntax verification (no docker required)"
            if [ ! -f "${DOH_OVERLAY}" ]; then
                printf "%seve doh verify: SKIPPED — %s not found%s\n" "${C_YELLOW}" "${DOH_OVERLAY}" "${C_RESET}"
                return 0
            fi
            local rc=0
            printf "  %s ........ " "${DOH_OVERLAY}"
            if python -c "import yaml; yaml.safe_load(open('${DOH_OVERLAY}'))" >/dev/null 2>&1; then
                printf "%sparse OK%s\n" "${C_GREEN}" "${C_RESET}"
            else
                printf "%sPARSE FAIL%s\n" "${C_RED}" "${C_RESET}"; rc=1
            fi
            printf "  %s ........ " "${DOH_CONFIG}"
            if [ -f "${DOH_CONFIG}" ]; then
                if python -c "import yaml; yaml.safe_load(open('${DOH_CONFIG}'))" >/dev/null 2>&1; then
                    printf "%sparse OK%s\n" "${C_GREEN}" "${C_RESET}"
                else
                    printf "%sPARSE FAIL%s\n" "${C_RED}" "${C_RESET}"; rc=1
                fi
            else
                printf "%smissing (will be created on first up)%s\n" "${C_YELLOW}" "${C_RESET}"
            fi
            if [ "${rc}" = "0" ]; then
                printf "%seve doh verify: PASS%s\n" "${C_GREEN}" "${C_RESET}"
            else
                printf "%seve doh verify: FAIL%s\n" "${C_RED}" "${C_RESET}"
            fi
            return "${rc}"
            ;;
        test)
            goto_stack_dir
            if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
                if ! docker ps --format '{{.Names}}' | grep -q "^${DOH_CONTAINER}$"; then
                    info "eve doh test: SKIPPED — ${DOH_CONTAINER} not running"
                    return 0
                fi
            else
                info "eve doh test: SKIPPED — docker daemon not reachable"
                return 0
            fi
            header "DoH resolver smoke test (127.0.0.1:5053)"
            local resp=""
            if command -v dig >/dev/null 2>&1; then
                resp=$(dig @127.0.0.1 -p 5053 example.com +short 2>/dev/null || true)
            elif command -v nslookup >/dev/null 2>&1; then
                resp=$(nslookup example.com 127.0.0.1 2>/dev/null | grep -E '^Address' | tail -n +2 || true)
            else
                err "neither dig nor nslookup available"
                return 1
            fi
            if [ -n "${resp}" ]; then
                printf "%seve doh test: PASS%s\n" "${C_GREEN}" "${C_RESET}"
                printf "  response: %s\n" "${resp}"
                return 0
            else
                printf "%seve doh test: FAIL%s (empty response)\n" "${C_RED}" "${C_RESET}"
                return 1
            fi
            ;;
        ""|-h|--help|help)
            cat <<EOF
${C_PURPLE}${C_BOLD}eve doh${C_RESET} — Cloudflared DNS-over-HTTPS sidecar management

${C_BOLD}USAGE${C_RESET}
  eve doh <subcommand> [args]

${C_BOLD}SUBCOMMANDS${C_RESET}
  up                  Start the cloudflared DoH sidecar.
  down                Stop and remove the cloudflared sidecar.
  status              Show 'docker ps' filtered on ${DOH_CONTAINER}.
  verify              Syntax-check DoH artifacts (no docker daemon required).
                      Cleanly skips with exit 0 if ${DOH_OVERLAY} not yet present.
  test                dig (or nslookup) example.com against 127.0.0.1:5053.
                      Exits 0 on PASS or if container not running; exit 1 only on hard error.
  help                This help.

${C_DIM}Author: RKOJ-ELENO :: 2026-05-24${C_RESET}
EOF
            ;;
        *)
            err "unknown subcommand: doh ${action}"
            info "run 'eve doh help' for usage"
            return 1
            ;;
    esac
}

cmd_proxy() {
    local action="${1:-}"; shift || true
    case "${action}" in
        list)
            goto_stack_dir
            header "Per-app proxy routes (Layer 3 of geo-mesh anonymity model)"
            if [ ! -f "${PROXY_ROUTES_FILE}" ]; then
                warn "${PROXY_ROUTES_FILE} not found — no routes configured yet"
                info "Run 'eve proxy set <app> <route>' to seed a row."
                return 0
            fi
            if ! python -c "import json; json.load(open('${PROXY_ROUTES_FILE}'))" >/dev/null 2>&1; then
                err "${PROXY_ROUTES_FILE} is not valid JSON"
                return 1
            fi
            local default_route
            default_route=$(python -c "import json; print(json.load(open('${PROXY_ROUTES_FILE}')).get('default','direct'))")
            printf "  %sdefault%s ........ %s\n" "${C_BOLD}" "${C_RESET}" "${default_route}"
            echo
            local row_count
            row_count=$(python -c "import json; print(len(json.load(open('${PROXY_ROUTES_FILE}')).get('routes',{})))")
            if [ "${row_count}" = "0" ]; then
                info "  (no per-app overrides; everything follows default route)"
            else
                printf "  %sapp                       route%s\n" "${C_BOLD}" "${C_RESET}"
                printf "  %s---                       -----%s\n" "${C_DIM}" "${C_RESET}"
                python -c "
import json
data = json.load(open('${PROXY_ROUTES_FILE}'))
for app, route in sorted(data.get('routes', {}).items()):
    print('  {:<25} {}'.format(app, route))
"
            fi
            echo
            info "Honest status: this CLI manages the routes.json file. Actual traffic"
            info "routing (nftables / netns wrap) is NOT yet implemented. See"
            info "PROXY-DESIGN.md for the design + deferred work."
            ;;
        set)
            local app="${1:-}"
            local route="${2:-}"
            if [ -z "${app}" ] || [ -z "${route}" ]; then
                err "usage: eve proxy set <app> <route>"
                info "valid routes: ${PROXY_VALID_ROUTES}"
                return 1
            fi
            # Validate route value
            local valid=0
            for r in ${PROXY_VALID_ROUTES}; do
                if [ "${r}" = "${route}" ]; then valid=1; break; fi
            done
            if [ "${valid}" = "0" ]; then
                err "invalid route: ${route}"
                info "valid routes: ${PROXY_VALID_ROUTES}"
                return 1
            fi
            if [ "${route}" = "tor" ]; then
                warn "route 'tor' accepted into config, but Tor exit is NOT implemented yet."
                warn "Traffic will continue to follow whatever default is in effect until the Tor wrapper lands."
            fi
            goto_stack_dir
            if [ ! -f "${PROXY_ROUTES_FILE}" ]; then
                err "${PROXY_ROUTES_FILE} not found; create the seed file first"
                return 1
            fi
            python - "${app}" "${route}" "${PROXY_ROUTES_FILE}" <<'PYEOF'
import json, sys
app, route, path = sys.argv[1], sys.argv[2], sys.argv[3]
with open(path) as f:
    data = json.load(f)
data.setdefault("routes", {})[app] = route
with open(path, "w") as f:
    json.dump(data, f, indent=2, sort_keys=True)
    f.write("\n")
PYEOF
            ok "set ${app} -> ${route}"
            info "Note: config-only update. No traffic re-routing happens until the netns/nftables layer ships."
            ;;
        show)
            local app="${1:-}"
            if [ -z "${app}" ]; then
                err "usage: eve proxy show <app>"
                return 1
            fi
            goto_stack_dir
            if [ ! -f "${PROXY_ROUTES_FILE}" ]; then
                err "${PROXY_ROUTES_FILE} not found"
                return 1
            fi
            local route
            route=$(python - "${app}" "${PROXY_ROUTES_FILE}" <<'PYEOF'
import json, sys
app, path = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
routes = data.get("routes", {})
if app in routes:
    print(routes[app])
else:
    print(data.get("default", "direct") + " (default)")
PYEOF
)
            printf "  %s -> %s\n" "${app}" "${route}"
