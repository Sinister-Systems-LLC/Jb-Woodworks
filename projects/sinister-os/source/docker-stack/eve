            fi
            printf "  routes.json parses ...... "
            if [ -f "${PROXY_ROUTES_FILE}" ] && python -c "import json; json.load(open('${PROXY_ROUTES_FILE}'))" >/dev/null 2>&1; then
                printf "%sparse OK%s\n" "${C_GREEN}" "${C_RESET}"
            else
                printf "%sPARSE FAIL%s\n" "${C_RED}" "${C_RESET}"; rc=1
            fi
            if [ "${rc}" = "0" ]; then
                local row_count
                row_count=$(python -c "import json; print(len(json.load(open('${PROXY_ROUTES_FILE}')).get('routes',{})))")
                printf "  row count ............... %s\n" "${row_count}"
                printf "  routes valid check ...... "
                local bad
                bad=$(python - "${PROXY_ROUTES_FILE}" "${PROXY_VALID_ROUTES}" <<'PYEOF'
