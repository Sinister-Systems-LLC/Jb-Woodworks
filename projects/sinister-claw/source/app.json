{
  "_comment": "RKOJ Mobile :: app.json -- Author: RKOJ-ELENO :: 2026-05-21",
  "expo": {
    "name": "RKOJ",
    "displayName": "RKOJ",
    "slug": "rkoj",
    "scheme": "rkoj",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "primaryColor": "#A06EFF",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#0E0A14",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.rkojeleno.rkoj.ios",
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSFaceIDUsageDescription": "RKOJ uses Face ID to unlock the operator's Tailscale token."
      }
    },
    "android": {
      "package": "com.rkojeleno.rkoj",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0A14"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
