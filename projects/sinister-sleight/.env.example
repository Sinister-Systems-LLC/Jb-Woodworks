# Author: RKOJ-ELENO :: 2026-05-24
# Sinister Sleight .env.example
# Copy to .env and fill in real values. .env is gitignored.
# NEVER commit real keys.

# === Broker (paper-trading only at P1-P5) ===
# Get paper-trading keys from https://app.alpaca.markets/paper/dashboard/overview
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
ALPACA_PAPER_ENDPOINT=https://paper-api.alpaca.markets

# === Broker (real-money — DO NOT FILL until P6 operator-go) ===
# These remain empty until operator explicit go-live signal
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=
ALPACA_LIVE_ENDPOINT=https://api.alpaca.markets

# === Optional paid data feeds (P4+) ===
POLYGON_API_KEY=
IEX_API_KEY=

# === LLM trader (Claude / Anthropic) ===
# Read from fleet-wide ANTHROPIC_API_KEY if set; otherwise use this
ANTHROPIC_API_KEY=

# === Kill-switch + risk overrides ===
# Set to "1" to force kill-switch ON regardless of inbox state (default: 1)
SLEIGHT_REAL_MONEY_ENABLED=0
# Cap max equity for any single strategy in USD
SLEIGHT_MAX_EQUITY_PER_STRATEGY_USD=1000
# Cap daily quantum cloud Wukong-180 seconds (operator-set)
SLEIGHT_QUANTUM_CLOUD_BUDGET_SEC=0
