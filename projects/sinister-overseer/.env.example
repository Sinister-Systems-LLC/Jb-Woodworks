# Author: RKOJ-ELENO :: 2026-05-24
# Sinister Overseer .env.example
# Copy to .env and fill in real values. .env is gitignored.
# NEVER commit real keys.

# === Anthropic API KEY (DEPRECATED PATH) ===
# DO NOT export ANTHROPIC_API_KEY in production. Per oauth-pivot doctrine
# (oauth-pivot-max-quota-pooling-2026-05-24), exporting this hijacks billing
# from Max quota -> Console pay-as-you-go.
# Overseer's Claude calls should route through claude-oauth-accounts.ps1
# round-robin pool, not direct SDK call with API key.
# Only set this if doing local dev / smoke testing OUTSIDE the spawn pipeline.
ANTHROPIC_API_KEY=

# === Per-attachment cost cap (defaults applied in code) ===
# Default $5/day cost-eq per attached project. Override per attachment in
# config/attached-projects.json -> attachments[*].cost_cap_usd_per_day.
OVERSEER_DEFAULT_COST_CAP_USD_PER_DAY=5.0

# === Throttle + suspend thresholds (0.0-1.0 of cap) ===
OVERSEER_THROTTLE_AT_PCT=0.80
OVERSEER_SUSPEND_AT_PCT=1.00

# === Polling cadence overrides (seconds) ===
# Per-project-type defaults applied in adapter; only set these to override
# all attachments globally (rare).
OVERSEER_DEFAULT_CHAT_POLL_SEC=300
OVERSEER_DEFAULT_FILE_POLL_SEC=1800
OVERSEER_DEFAULT_ML_POLL_SEC=3600

# === Opus-4.7 rate limit (per-attachment per-day) ===
OVERSEER_OPUS_RATE_LIMIT_PER_DAY=5

# === Cross-project aggregator (daily UTC midnight + 30 min) ===
OVERSEER_AGGREGATOR_ENABLED=1
OVERSEER_AGGREGATOR_MIN_PROJECTS_FOR_PROMOTION=2
OVERSEER_AGGREGATOR_WINDOW_DAYS=30

# === Lessons DB ===
OVERSEER_LESSONS_DB_PATH=lessons.db

# === Heartbeat cadence ===
OVERSEER_HEARTBEAT_SEC=60
