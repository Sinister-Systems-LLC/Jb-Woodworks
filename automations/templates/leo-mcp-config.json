        "sinister-bus": "Fleet orchestrator + runlog. Tier 1 Python, no API cost.",
        "sentinel": "Date alarms (yurikey expiry, deadlines). Tier 1.",
        "translator": "MCP-tool catalog search across 200+ tools. Tier 1.",
        "watcher": "Source-drift detection (sha + mtime). Tier 1.",
        "auditor": "Secrets + dedup + freshness scan. Tier 1.",
        "custodian": "Active backup to D:\\_backups\\. Tier 1.",
        "stealth-browser": "Undetected Chromium automation. Tier 1.",
        "librarian": "RAG over 8500+ .md archive (Ollama + FAISS).",
