# .env.example - sanctum-git
# Author: Sinister Sanctum master agent (Claude) :: 2026-05-19
#
# Copy this file to `.env` (same directory) and fill in real values AFTER you've
# completed the Gitea install wizard at http://localhost:3000.
#
# The git-mirror.ps1 tool reads these values to authenticate against the Gitea
# REST API (basic auth: GITEA_ADMIN_USER + GITEA_ADMIN_PASSWORD). Treat .env as
# secret — it is git-ignored by convention (the repo root .gitignore should
# include `tools/sanctum-git/.env`).

# Admin user you create in the install wizard ("Set as administrator" checkbox).
GITEA_ADMIN_USER=operator

# Email for the admin user (matches operator's address).
GITEA_ADMIN_EMAIL=andrew.viperrr@gmail.com

# Password for the admin user. Set this IN THE GITEA UI on first run, then mirror
# it here. Do NOT pick a real password before the wizard exists to accept it.
GITEA_ADMIN_PASSWORD=set_in_gitea_ui_first_run

# Optional: SECRET_KEY shown by Gitea after the wizard completes (Site
# Administration -> Configuration). Used for token signing on this instance.
# Leave blank until the wizard generates it.
GITEA_SECRET_KEY=set_after_init

# Optional: only set if you uncomment the gitea-runner service in
# docker-compose.yml. Get the token from Site Administration -> Actions -> Runners.
RUNNER_TOKEN=
