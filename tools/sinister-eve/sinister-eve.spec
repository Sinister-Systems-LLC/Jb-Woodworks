# Console app (not windowed) — operator runs it in a terminal.

block_cipher = None

a = Analysis(
    ['sinister_eve/__main__.py'],
    pathex=['.'],
    binaries=[],
    datas=[],
    hiddenimports=[],
    hookspath=[],
    runtime_hooks=[],
    excludes=[],
    cipher=block_cipher,
    noarchive=False,
