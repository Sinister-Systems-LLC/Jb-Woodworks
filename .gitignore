# Sinister LLC monorepo - global ignores

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
.next/
out/
.parcel-cache/
.turbo/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Java / Android / AOSP
*.class
*.jar
*.apk
*.aab
*.dex
*.o
*.a
.gradle/
.idea/
*.iml
local.properties
captures/

# OS
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# IDE
.vscode/
.cursor/
*.swp
*.swo

# Secrets - HARD RULE: nothing under these paths/patterns ever commits
.env
.env.*
!.env.example
*.pem
*.key
!**/*.public.key
credentials.json
credentials/
secrets/
yurikey*.xml
**/keybox/*.xml

# Sinister-specific runtime/operator-private
_backups/
_logs/
runtime-state/
01_MEMORY/_bus/
01_MEMORY/_consolidated/
agents/**/learned.md
agents/**/index/
agents/**/findings/
agents/**/screenshots/
agents/**/.venv/
01_MEMORY/_AUTOGEN-NOTE.md
*.tmp.*
*.bak.*

# Operator-private vault (auth keys, leo handoff, desktop archive junction) — NEVER pushed
_vault/

# Sanctum runtime state (per-agent heartbeats, operator-action queue jsonl, spawned-window log, prefs)
_shared-memory/heartbeats/
_shared-memory/operator-requests.jsonl
_shared-memory/spawned-windows.jsonl
_shared-memory/agent-prefs.json
_shared-memory/.auto-push.lock
_shared-memory/auto-push.log
_shared-memory/auto-push.log.*

# Built artifacts (rebuildable; should not be in source control)
automations/window-manager/_build-logs/
automations/window-manager/dist/
*.exe

# RKOJ source-only asset originals (large .bak / .webp masters); kept on
# disk for re-export but excluded from EXE bundle + git. See agent A note
# 2026-05-19: web/_assets-src/ replaced loose web/*.bak + _logo-source.webp.
automations/window-manager/web/_assets-src/

# Captured / experimental
captures/
*-capture-*.json
*-debug-*.json

# Knowledge graph + Obsidian local-only
.obsidian/workspace*.json
.obsidian/cache
06_UNDERSTAND/**/graph.json.tmp

# Nested per-project git repos under projects/ — these are junctions/clones of product
# repos owned by per-project agents (snap-emu, panel, kernel-apk, tiktok-emu). Sanctum
# must NOT pin them as gitlinks; lane discipline says each product repo pushes itself.
# Scaffold READMEs / non-source content at projects/<repo>/ root stays tracked.
projects/*/source/
projects/*/source/source/

# Sinister TikTok EMU project root holds its own .git (sister product repo, lane-owned
# by tiktok-emu agent). Excluding the whole tree from Sanctum.
projects/sinister-tiktok-emu/

# External-imports inflow loop — KEEP operator-authored audit trail
# (CANDIDATES.md, README.md, per-slug ATTRIBUTION.md, notes.md, etc.);
# EXCLUDE upstream-cloned source code (bulky, may pattern-match secrets in
# test fixtures, not Sanctum's to vendor). Add a submodule deliberately if a
# clone needs to ship. Updated 2026-05-19 by master to un-block the audit trail.
_shared-memory/external-imports/*/v3/
_shared-memory/external-imports/*/node_modules/
_shared-memory/external-imports/*/bin/
_shared-memory/external-imports/*/build/
_shared-memory/external-imports/*/dist/
_shared-memory/external-imports/*/docs/
_shared-memory/external-imports/*/plugin/
_shared-memory/external-imports/*/plugins/
_shared-memory/external-imports/*/ruflo/
_shared-memory/external-imports/*/scripts/
_shared-memory/external-imports/*/tests/
_shared-memory/external-imports/*/verification/
_shared-memory/external-imports/*/*.rvf
_shared-memory/external-imports/*/*.rvf.lock
_shared-memory/external-imports/*/*.gif
_shared-memory/external-imports/*/*.png
_shared-memory/external-imports/*/package*.json
_shared-memory/external-imports/*/pnpm-lock.yaml
_shared-memory/external-imports/*/yarn.lock
_shared-memory/external-imports/*/tsconfig*.json
_shared-memory/external-imports/*/CLAUDE*.md
_shared-memory/external-imports/*/AGENTS.md
_shared-memory/external-imports/*/SECURITY.md
_shared-memory/external-imports/*/CHANGELOG.md
_shared-memory/external-imports/*/README.md

# preserved upstream-clone .git history (renamed to neutralize embedded-repo detection)
_shared-memory/external-imports/*/.git-clone-backup/

# external-imports/<slug>/ — additional upstream dotfiles + manifests + hidden dirs that the
# clone brings in but we don't want vendored into Sanctum
_shared-memory/external-imports/*/.agents/
_shared-memory/external-imports/*/.github/
_shared-memory/external-imports/*/.claude/
_shared-memory/external-imports/*/.gitignore
_shared-memory/external-imports/*/.npmignore
_shared-memory/external-imports/*/.npmrc
_shared-memory/external-imports/*/.editorconfig
_shared-memory/external-imports/*/.prettierrc*
_shared-memory/external-imports/*/.eslintrc*
